# .env template
# Copy this, rename to .env, fill in your actual values
# NEVER commit .env to Git - add to .gitignore

# PostgreSQL Database URL
# Format: postgresql://username:password@hostname:5432/database_name
# Get from Render database dashboard after creation
DATABASE_URL=postgresql://user:password@localhost:5432/linksmatch

# SerpApi Key
# Get from https://serpapi.com/dashboard
# Free tier: 100 searches/month
SERPAPI_KEY=your_serpapi_api_key_here

# Frontend Base URL (for CORS - optional, defaults to localhost)
FRONTEND_URL=http://localhost:3000
